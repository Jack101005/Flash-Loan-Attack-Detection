# --- [ DATABASE & CACHE CONFIG ] ---
# MongoDB (Để Dashboard lấy dữ liệu)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password123
MONGO_URI=mongodb://admin:password123@mongodb:27017/flashloan?authSource=admin

# Redis (Để Price-feed và Processing job dùng chung)
REDIS_HOST=redis
REDIS_PORT=6379

# --- [ MESSAGING CONFIG ] ---
# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=raw_txns

# --- [ SPARK CONFIG ] ---
# Spark Master (Để Processing Job gửi task lên)
SPARK_MASTER_URL=spark://spark-master:7077

# --- [ APP SERVICES CONFIG ] ---
# Ingestion Service (Ví dụ: Web3 Provider, API Keys)
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_project_id
BLOCKCHAIN_NETWORK=ethereum

# Price Feed Service (Ví dụ: API từ CoinGecko/Binance)
PRICE_API_KEY=your_api_key_here

# Dashboard (Streamlit)
DASHBOARD_PORT=8501
DEBUG_MODE=true